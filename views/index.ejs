<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Messages</title>
  </head>
  <body>
    <div>
      <% messages.forEach((message) => { %>
      <div>
        <h2><%= message.user %></h2>
        <p><%= message.text %></p>
        <p><%= message.added %></p>
        <a href="/message/<%=message.id%>">Open</a>
      </div>
      <%}) %>
    </div>
    <a href="/new">New message</a>
  </body>
</html>
